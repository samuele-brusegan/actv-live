# Database (GTFS data)
DB_HOST=localhost
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=actv_live

# Password per l'area /admin/* (login form). CAMBIARLA in produzione.
ADMIN_PASSWORD=changeme

# Feed GTFS candidati, separati da virgola. Viene scelto quello con Last-Modified più recente.
GTFS_URLS=https://actv.avmspa.it/sites/default/files/attachments/opendata/automobilistico/actv_aut.zip

# Binario PHP CLI usato per avviare l'aggiornamento in background da PHP-FPM.
# Nei container PHP ufficiali è normalmente /usr/local/bin/php.
GTFS_PHP_CLI=/usr/local/bin/php
